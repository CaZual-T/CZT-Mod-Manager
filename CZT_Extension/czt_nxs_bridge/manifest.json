{
  "manifest_version": 3,
  "name": "CZT Nexus Bridge",
  "version": "0.2.0",
  "description": "Monitors 'nexusmods.com' for 'manual' download clicks. Then automatically triggers CZT Mod Manager to handle install.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.nexusmods.com/*", "https://api.nexusmods.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.nexusmods.com/*"],
      "js": ["utils/content_dom.js", "utils/content_payload.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_title": "CZT Nexus Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
